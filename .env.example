# 复制为 .env 后填入真实值。.env 已被 .gitignore 忽略，切勿提交真实密钥。
# 以下为占位，具体供应商在里程碑 M1 确认后再最终确定。

# === 模拟盘券商（美股/ETF/加密，默认 paper trading）===
# 示例：Alpaca paper trading
BROKER_PROVIDER=alpaca_paper
ALPACA_API_KEY_ID=your_key_here
ALPACA_API_SECRET=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === 行情 / 历史数据源 ===
MARKET_DATA_PROVIDER=your_provider_here
MARKET_DATA_API_KEY=your_key_here

# === 新闻 / 基本面 / 情绪数据源（供 LLM 信号层使用）===
NEWS_DATA_PROVIDER=your_provider_here
NEWS_DATA_API_KEY=your_key_here

# === LLM 供应商（信号提取）===
LLM_PROVIDER=your_provider_here
LLM_API_KEY=your_key_here
LLM_MODEL=your_model_here
# 为可复现，运行时应固定 model 版本与温度
LLM_TEMPERATURE=0

# === 运行环境标志（关键安全护栏）===
# paper | live —— 除非明确切换，永远保持 paper
TRADING_MODE=paper
# 全局熔断开关（kill switch），true 时禁止任何下单
KILL_SWITCH=false
